# Ritual CLI Environment Configuration
# Copy this to .env and fill in your values

# ── Ritual Chain RPC ──────────────────────────────────────────────────────────────
# Devnet (free, for testing)
RITUAL_RPC_URL=https://devnet.ritual.network
# Mainnet (when ready)
# RITUAL_RPC_URL=https://mainnet.ritual.network

# Chain ID
RITUAL_CHAIN_ID=11022  # devnet; mainnet differs

# ── Your Wallet ───────────────────────────────────────────────────────────────────
# Either export PRIVATE_KEY, or use hermes wallet integration
RITUAL_PRIVATE_KEY=0xYOUR_DEVNET_PRIVATE_KEY_HERE

# Or use Hermes wallet (recommended for mainnet)
# RITUAL_USE_HERMES_WALLET=true

# ── Contract Addresses ────────────────────────────────────────────────────────────
# After deployment, update these
AGENT_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
REPUTATION_TRACKER_ADDRESS=0x0000000000000000000000000000000000000001

# ── Data Availability (DA) Layer ─────────────────────────────────────────────────
# Optional: if storing agent code blobs on Ritual DA
DA_ENABLED=true
DA_BLOB_SIZE_LIMIT=10240  # bytes, adjust per precompile limits

# ── Agent Configuration ──────────────────────────────────────────────────────────
# Default heartbeat interval (seconds)
HEARTBEAT_INTERVAL=300

# Reputation decay rate (per day)
REPUTATION_DECAY_RATE=0.01  # 1% per day

# ── Telegram Notifications (optional) ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=123456789

# ── LLM Scoring (for auditor agent) ──────────────────────────────────────────────
# Uses ritual-dapp-llm — defaults to Ritual's hosted inference
AUDIT_MODEL=ritual-llm-v1
AUDIT_TEMPERATURE=0.3

# ── Logging ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO  # DEBUG, INFO, WARN, ERROR
LOG_FILE=~/.ritual-agent-registry/logs/agent-registry.log
